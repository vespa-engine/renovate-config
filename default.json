{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assigneesFromCodeOwners": true,
  "dependencyDashboardApproval": true,
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "description": [ "The default configuration that is extended by the onboarding PRs" ],
  "extends": [
    "config:best-practices",
    "security:openssf-scorecard",
    ":dependencyDashboard"
  ],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 10,
  "ignoreDeps": [],
  "ignorePaths": [],
  "osvVulnerabilityAlerts": true,
  "reviewersFromCodeOwners": true,
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": [ "Disable version updates for Vespa artifacts" ],
      "matchPackageNames": ["/^com\\.yahoo\\.vespa/", "/^ai\\.vespa/"],
      "matchManagers": ["maven", "gradle"],
      "enabled": false
    },
    {
      "description": [ "Group all GitHub Actions updates into a single PR" ],
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": [ "Group Maven: org.codehaus.plexus" ],
      "matchPackageNames": ["/^org\\.codehaus\\.plexus/"],
      "matchManagers": ["maven", "gradle"],
      "groupName": "Maven: Codehaus Plexus"
    }
  ]
}
